#!/bin/bash
# Unified Claude Code alert controller.
# Installed to ~/.local/bin/alert — on PATH in every shell, no .zshrc needed.
#
# Usage:
#   alert stop      — stop active alert (also: off / silence / mute / quiet)
#   alert start     — start alert manually
#   alert status    — show current state
#
# Official stop commands:
#   alert stop      (preferred)
#   stop-alert      (backup)
#
# Note: "stop alert" (reversed, with a space) is NOT supported.
# In zsh/bash, "stop" is a job-control builtin; overriding it is unsafe.

ALERT_DIR="$HOME/.claude/alert"
RUNNING="$ALERT_DIR/running"
PIDFILE="$ALERT_DIR/pid"
SUPPRESSION="$ALERT_DIR/suppressed"
SOUND="/System/Library/Sounds/Hero.aiff"
SUPPRESS_SECONDS=30

mkdir -p "$ALERT_DIR"

# Normalise: lowercase + strip hyphens so stop/STOP/stop-alert/alertstop all match
cmd=$(echo "${1:-status}" | tr '[:upper:]' '[:lower:]' | tr -d '-')

case "$cmd" in

  stop|off|silence|quiet|mute|stopalert|alertstop)
    # 1. Write suppression FIRST — prevents next Stop hook from restarting the alert
    touch "$SUPPRESSION"

    if [ ! -f "$RUNNING" ]; then
      echo "No alert running. Suppression set for ${SUPPRESS_SECONDS}s."
      exit 0
    fi

    # 2. Remove running sentinel — loop will not restart after this point
    rm -f "$RUNNING"

    # 3. Kill the currently-playing afplay so sound stops immediately
    pkill -x afplay 2>/dev/null

    # 4. Kill the bash loop itself (cleanup; loop would exit on its own, but faster this way)
    if [ -f "$PIDFILE" ]; then
      PID=$(cat "$PIDFILE")
      kill "$PID" 2>/dev/null
      sleep 0.2
      kill -9 "$PID" 2>/dev/null
      rm -f "$PIDFILE"
    fi

    echo "Alert stopped. Next Claude response suppressed for ${SUPPRESS_SECONDS}s."
    ;;

  start|on)
    ~/.claude/claude-alert-start.sh
    ;;

  status)
    if [ -f "$RUNNING" ] && [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
      echo "Alert is RUNNING (loop PID $(cat "$PIDFILE"))."
    else
      echo "No alert running."
    fi
    if [ -f "$SUPPRESSION" ]; then
      AGE=$(( $(date +%s) - $(stat -f %m "$SUPPRESSION") ))
      if [ "$AGE" -lt "$SUPPRESS_SECONDS" ]; then
        echo "Suppression active: ${AGE}s / ${SUPPRESS_SECONDS}s elapsed."
      fi
    fi
    ;;

  *)
    echo "Usage: alert stop|start|status"
    exit 1
    ;;
esac
