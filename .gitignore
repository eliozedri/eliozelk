# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# macOS Finder duplicates (files with " 2", " 3", " 4" suffixes)
"* 2.*"
* 2.*
* 3.*
* 4.*

# misc local dirs
.superpowers/
catalog/

# Claude Code project-local skills (third-party, not vendored)
.claude/skills/
# Claude Code local session metadata
.claude/skills-installed.local.md
.backups/

# Local-only artifacts (not for deployment)
neural_core_asset_extract_v1/
.claude/scheduled_tasks.lock
